tpch_workshop:
  target: dev
  outputs:
    dev:
      type: snowflake
      role: dbt_workshop_role
      warehouse: dbt_workshop_wh
      database: dbt_workshop_db
      schema: workshop
      threads: 4

    prod:
      type: snowflake
      role: dbt_workshop_role
      warehouse: dbt_workshop_wh
      database: dbt_workshop_db
      schema: prod
      threads: 8

# ⚠️ Snowflake 네이티브 dbt 규칙:
# - password, authenticator, account, user 필드 사용 금지
# - env_var() 사용 금지
# - 이 파일은 dbt_project.yml과 같은 폴더에 위치해야 합니다 (~/.dbt/ 아님)
# - Snowflake가 실행 컨텍스트에서 연결을 직접 처리합니다
